# ==============================================================================
# Deep Behavioral Biometrics Authentication Platform — Environment Variables
# ==============================================================================
#
# Copy this file to a new file named ".env" in the project root, and fill in
# real values as needed. The ".env" file should NEVER be committed to version
# control (it should be listed in .gitignore) since it may contain secrets.
#
# The defaults below are safe for local development only.
# ==============================================================================

# --- MongoDB Configuration ---
# Connection string for your MongoDB instance.
# For local MongoDB (installed via mongodb-community or Docker):
MONGO_URI=mongodb://localhost:27017

# For MongoDB Atlas (cloud-hosted), it would look like:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority

# Name of the database used by this application.
DATABASE_NAME=behavioral_biometrics_db

# --- JWT / Security Configuration ---
# Secret key used to sign JWT access tokens.
# IMPORTANT: Change this to a long, random, unique string before any real
# deployment. You can generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev_only_secret_key_change_this_in_production

# Algorithm used to sign JWTs. HS256 is the standard symmetric algorithm.
JWT_ALGORITHM=HS256

# How long an access token remains valid, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Application Metadata ---
APP_NAME=Deep Behavioral Biometrics Authentication Platform

# --- CORS Configuration ---
# Comma-separated list of frontend origins allowed to call this API.
# Streamlit's default local development port is 8501.
